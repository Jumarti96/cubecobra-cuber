# Virtual environment
.venv/

# Local cube data (fetched & enriched files — not committed)
cubes/

# Environment variables (contains API keys)
.env

# Claude Code settings (generated by agent_env/install_claude_env.py, not committed
# so the repo never changes a collaborator's environment without being asked)
.claude/settings.json
.claude/settings.local.json
.claude/skills/

# Python cache
__pycache__/
*.pyc
*.pyo
*.pyd
.Python

# Distribution / packaging
*.egg-info/
dist/
build/

# SQLite cache
*.db

# OS
.DS_Store
Thumbs.db

# Editor
.vscode/
.idea/
*.swp

# Local context files (design AI, notes)
.context-*.md

# OpenSpec planning workspace (local only)
openspec/

# Superpowers design specs (local planning artifacts, not committed)
docs/superpowers/

# Temp scripts written by build-deck during a run (gitignored for all users)
_workspace/

# Skill-creator eval workspaces (scratch, not committed)
*-workspace/

# Current cube config (local only — do not commit)
.cuber-config.json

# Orchestrator run ledger (local build state)
runs/
