.claude/settings.local.json
.claude/skills/

# Python cache
__pycache__/
*.pyc
*.pyo
*.pyd
.Python

# Distribution / packaging
*.egg-info/
dist/
build/

# SQLite cache
*.db

# OS
.DS_Store
Thumbs.db

# Editor
.vscode/
.idea/
*.swp

# Local context files (design AI, notes)
.context-*.md

# OpenSpec planning workspace (local only)
openspec/

